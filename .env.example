# Copie para .env e preencha conforme o ambiente (não commite segredos).

# Webhook do Microsoft Teams (Incoming Webhook). Se preenchido e a reserva tiver
# observações, é enviado um POST com texto resumindo sala, datas, horário, etc.
VITE_TEAMS_WEBHOOK_URL=

# E-mails de administradores (podem cancelar qualquer reserva). Separados por vírgula.
VITE_ADMIN_EMAILS=admin@empresa.com.br

# Identidade de quem usa a app neste build (cancelar / criador). Deve coincidir com
# o e-mail do utilizador para permissões de cancelamento quando não for admin.
VITE_USER_EMAIL=
